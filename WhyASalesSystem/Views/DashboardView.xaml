<UserControl x:Class="WhyASalesSystem.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WhyASalesSystem.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#F5F5F5" Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Dashboard"
               FontSize="28"
               FontWeight="Bold"/>

        <UniformGrid Grid.Row="2" Columns="4">

            <Border Margin="10" Padding="15" Background="White" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Today's Sales" FontWeight="Bold"/>
                    <TextBlock Text="฿25,430" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Margin="10" Padding="15" Background="White" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Orders"/>
                    <TextBlock Text="128" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Margin="10" Padding="15" Background="White" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Products"/>
                    <TextBlock Text="856" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Margin="10" Padding="15" Background="White" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Low Stock"/>
                    <TextBlock Text="12" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>

        </UniformGrid>

    </Grid>
</UserControl>
