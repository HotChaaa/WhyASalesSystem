<UserControl x:Class="WhyASalesSystem.Views.SaleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WhyASalesSystem.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#F5F5F5" Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ฝั่งซ้าย -->
        <StackPanel Grid.Column="0">

            <TextBlock Text="Sale"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

            <TextBox Height="35"
                 Margin="0,0,0,15"
                 Text="ค้นหาสินค้า / Barcode"/>

            <DataGrid Height="450"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="120"/>
                    <DataGridTextColumn Header="Product" Binding="{Binding Product}" Width="*"/>
                    <DataGridTextColumn Header="Qty" Binding="{Binding Qty}" Width="70"/>
                    <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="90"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="100"/>
                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>

        <!-- ฝั่งขวา -->
        <Border Grid.Column="1"
            Margin="20,0,0,0"
            Background="White"
            CornerRadius="8"
            Padding="20">

            <StackPanel>

                <TextBlock Text="Summary"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

                <TextBlock Text="Items : 5"
                       FontSize="16"/>

                <TextBlock Text="Total : ฿1,250.00"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,20,0,20"/>

                <Button Content="Cash"
                    Height="45"
                    Margin="0,5"/>

                <Button Content="QR Payment"
                    Height="45"
                    Margin="0,5"/>

                <Button Content="Cancel"
                    Height="45"
                    Margin="0,5"/>

            </StackPanel>

        </Border>

    </Grid>
</UserControl>
