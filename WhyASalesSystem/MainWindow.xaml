<Window x:Class="WhyASalesSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WhyASalesSystem"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#2D3748">

            <DockPanel>

                <!-- User -->
                <StackPanel DockPanel.Dock="Top" Margin="10">
                    <TextBlock Text="Why A Sales System"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"/>

                    <Separator Margin="0,10"/>

                    <TextBlock Text="User"
                           Foreground="#CFCFCF"/>

                    <TextBlock x:Name="txtCurrentUser"
                           Text="admin"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,5,0,15"/>

                    <Button x:Name="btnLogout"
                        Content="Logout"
                        Height="40"
                        Click="btnLogout_Click"/>
                </StackPanel>

                <!-- Menu -->
                <StackPanel Margin="10">

                    <Button x:Name="btnDashboard"
                        Content="🏠 Dashboard"
                        Height="40"
                        Margin="0,5"
                        Click="btnDashboard_Click"/>

                    <Button x:Name="btnSale"
                        Content="🛒 Sale"
                        Height="40"
                        Margin="0,5"
                        Click="btnSale_Click"/>

                    <Button x:Name="btnInventory"
                        Content="📦 Inventory"
                        Height="40"
                        Margin="0,5"
                        Click="btnInventory_Click"/>

                </StackPanel>

            </DockPanel>

        </Border>

        <!-- Content -->
        <Grid Grid.Column="1" Background="#F5F5F5">
            <ContentControl x:Name="MainContent"/>
        </Grid>

    </Grid>
</Window>
